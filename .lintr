linters: linters_with_defaults(
    # Distribution constructors (Normal(), Gamma(), ...) and internal S3 helpers
    # (.print.dist_spec) use intentional non-snake_case names
    object_name_linter = NULL,
    # data.table non-standard evaluation (`:=`, bare column names) trips the
    # usage linter with false positives
    object_usage_linter = NULL
  )
exclusions: c(
    list.files("tests", recursive = TRUE, full.names = TRUE),
    list.files("inst", recursive = TRUE, full.names = TRUE)
  )
